# Database Configuration
# For local development, use PostgreSQL running on your machine
echo "DATABASE_URL=postgresql://user:password@localhost:5432/f1_predictor" >> .env.example
echo "DATABASE_POOL_SIZE=10" >> .env.example
echo "DATABASE_MAX_OVERFLOW=20" >> .env.example

# Jolpica F1 API (Free, no API key needed)
JOLPICA_API_BASE_URL=https://api.jolpi.ca/ergast/f1

# OpenWeather API
# Get your free API key at: https://openweathermap.org/api
# Free tier: 1,000 calls/day, 60 calls/minute
OPENWEATHER_API_KEY=your_key_here

# Application Settings
ENV=development

# Security
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-minimum-32-characters

# API Configuration
# Cache duration in hours for external API responses
API_CACHE_TTL=6

# Rate limiting in calls per second
API_RATE_LIMIT=2.0

# Server Configuration
HOST=0.0.0.0
PORT=8000